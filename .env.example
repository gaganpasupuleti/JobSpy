# Copy to .env and fill in values for local development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobboard
ADMIN_API_KEY=change-me-in-production
CORS_ORIGINS=*
SCRAPE_SLEEP_SECONDS=45
DEFAULT_RESULTS_WANTED=20
DEFAULT_HOURS_OLD=168
DEFAULT_SITES=indeed,linkedin,naukri

# Railway sets PORT automatically for the API service.
# Worker service start command: python /app/run_worker.py --once --limit 5
