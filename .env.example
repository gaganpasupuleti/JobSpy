# Copy to .env and fill in values for local development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobboard
ADMIN_API_KEY=change-me-in-production
AUTH_SECRET=change-me-auth-secret
CORS_ORIGINS=*
SCRAPE_SLEEP_SECONDS=45
DEFAULT_RESULTS_WANTED=20
DEFAULT_HOURS_OLD=168
DEFAULT_SITES=indeed,linkedin,naukri,foundit
LINK_VERIFY_BATCH_SIZE=100
LINK_VERIFY_SLEEP_SECONDS=1.0
LINK_VERIFY_STALE_HOURS=72

# Railway sets PORT automatically for the API service.
# Worker scrape:  python /app/run_worker.py --once --limit 5
# Worker verify: python /app/run_worker.py --verify-links --verify-limit 200
